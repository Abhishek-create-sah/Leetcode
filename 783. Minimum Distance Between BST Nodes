class Solution {
    private int mn = Integer.MAX_VALUE ;
    private TreeNode prev = null ;
    private void inorder(TreeNode root ){
        if(root == null) return ;
        inorder(root.left);
        if(prev != null){
            mn = Math.min(mn,Math.abs(prev.val - root.val));
        }
        prev = root ;
        
        inorder(root.right );
    }
    public int minDiffInBST(TreeNode root) {
        inorder(root);
        return mn ;
    }
}
