class Solution {
    private boolean help(TreeNode l , TreeNode rt){
        if(l == null ||rt == null){
            return l == rt ;
        }

        if(l.val != rt.val) return false ;

        return help(l.left,rt.right) && help(l.right , rt.left) ;
    }
    public boolean isSymmetric(TreeNode root) {
        return root==null || help(root.left , root.right);
    }
}
