class Solution {
    public int eraseOverlapIntervals(int[][] inter) {
        // sort end  time
        Arrays.sort(inter, (a, b) -> Integer.compare(a[1], b[1]));
        // select the start
        int st = inter[0][1] ;
        int cnt = 0 ;
        for(int i = 1; i < inter.length ; i++){
            if(st <= inter[i][0]) { // satify no need to remove
                st = inter[i][1];
            }
            else {
                cnt++ ;
            }
            
        }
        return cnt ;
    }
}