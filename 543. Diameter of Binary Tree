class Solution {
    private int md = 0 ;
    private int height(TreeNode root){
        if(root == null) return 0;

        int lh = height(root.left);
        int rh = height(root.right);

        md = Math.max(md , lh+rh);

        return Math.max(lh,rh)+1 ;
    }
    public int diameterOfBinaryTree(TreeNode root) {
        if(root == null) return 0;
        height(root);
        return md;
    }
}
